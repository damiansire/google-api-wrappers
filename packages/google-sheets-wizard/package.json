{
  "name": "google-sheets-wizard",
  "version": "0.0.2",
  "description": "Read data from Google Sheets with a tiny, typed API (getRange, con mapeo opcional a objetos).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "jest --testMatch \"**/src/**/*.spec.ts\"",
    "build": "npm run clean && tsc",
    "build-test": "npm run build && jest --testMatch \"**/dist-test/builded-package.spec.ts\"",
    "test:types": "tsd",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm run build-test && npm run check:pack",
    "check:pack": "publint && attw --pack . --profile node16 --ignore-rules missing-export-equals"
  },
  "tsd": {
    "directory": "test-d"
  },
  "keywords": [
    "google sheets",
    "node.js",
    "npm package",
    "data manipulation",
    "spreadsheet",
    "automation",
    "javascript",
    "auth",
    "wrapper",
    "typescript"
  ],
  "author": "Damian Sire <damiansire@gmail.com> (https://damiansire.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damiansire/google-api-wrappers.git",
    "directory": "packages/google-sheets-wizard"
  },
  "bugs": {
    "url": "https://github.com/damiansire/google-api-wrappers/issues"
  },
  "homepage": "https://github.com/damiansire/google-api-wrappers/tree/main/packages/google-sheets-wizard#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "googleapis": "^140.0.0"
  },
  "type": "commonjs",
  "publishConfig": {
    "provenance": true
  },
  "peerDependencies": {
    "googleapis": ">=130"
  }
}
