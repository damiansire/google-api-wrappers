{
  "name": "google-sheets-wizard",
  "version": "0.0.2",
  "description": "Library for easy interaction with Google Sheets. Read, write, and update data effortlessly. Simplify your workflows and automate tasks.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "jest --testMatch \"**/src/**/*.spec.ts\"",
    "build": "npm run clean && tsc",
    "build-test": "npm run build && jest --testMatch \"**/dist-test/builded-package.spec.ts\"",
    "test:types": "tsd",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm run build-test"
  },
  "tsd": {
    "directory": "test-d"
  },
  "keywords": [
    "google sheets",
    "node.js",
    "npm package",
    "data manipulation",
    "spreadsheet",
    "automation",
    "javascript",
    "auth",
    "wrapper",
    "typescript"
  ],
  "author": "Damian Sire <damiansire@gmail.com> (https://damiansire.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damiansire/google-api-wrappers.git",
    "directory": "packages/google-sheets-wizard"
  },
  "bugs": {
    "url": "https://github.com/damiansire/google-api-wrappers/issues"
  },
  "homepage": "https://github.com/damiansire/google-api-wrappers/tree/main/packages/google-sheets-wizard#readme",
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "eslint": "^9.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.13.0"
  },
  "dependencies": {
    "googleapis": "^140.0.0"
  }
}
