{
  "name": "google-api-wrappers",
  "private": true,
  "description": "Lightweight Node.js wrappers for Google APIs — YouTube Data API and Google Sheets — each published to npm under its own name.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "test:types": "npm run test:types --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "size": "size-limit"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "size-limit": "^12.1.0",
    "tsd": "^0.33.0"
  }
}
